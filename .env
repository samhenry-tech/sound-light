# Shared, non-secret client config baked into every build. All VITE_* values
# are public (they ship in the SPA bundle). Per-deployment or machine-specific
# overrides go in .env.local (gitignored).

# --- Google Sign-In (public OAuth Web client id) ---
VITE_GOOGLE_CLIENT_ID=728917661766-qn9fosl7al289fhga3583sv7n4p3lmdj.apps.googleusercontent.com

# --- Spotify ---
VITE_SPOTIFY_CLIENT_ID=a35ad70cf30442f0a53ba22a95e85c8e
# Mock catalog/player by default; the deploy workflow forces this to false for prod.
VITE_SPOTIFY_MOCK=true

# --- Music provider selection ---
VITE_MUSIC_PROVIDER=spotify
