# Example variable values for the atmos infrastructure.
#
# Copy to `terraform.tfvars` and edit. `*.tfvars` is gitignored (only the
# `.example` is tracked), so real values never get committed.
#
# In CI the Google client id is passed via the TF_VAR_google_client_id
# environment variable instead — see .github/workflows/terraform.yml and
# infra/IMPLEMENTATION_NOTES.md.

# --- Core / naming --------------------------------------------------------- #
project     = "atmos"
environment = "dev"
region      = "us-east-1"

# --- Google Sign-In -------------------------------------------------------- #
# Google OAuth 2.0 *Web application* client ID (REQUIRED). No secret is needed:
# the identity pool verifies Google ID tokens directly. Register your app
# origins (http://localhost:3000 + the production URL) as authorised
# JavaScript origins on this client in the Google Cloud Console.
google_client_id = "1234567890-example.apps.googleusercontent.com"
