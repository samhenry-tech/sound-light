# Example remote backend configuration.
#
# This file is intentionally named `*.example` so Terraform ignores it. To use a
# remote S3 backend instead of the default local backend:
#
#   1. Create the state bucket and (optional) lock table out of band, e.g.:
#
#        aws s3api create-bucket \
#          --bucket sound-light-tfstate-<account-id> \
#          --region us-east-1
#        aws s3api put-bucket-versioning \
#          --bucket sound-light-tfstate-<account-id> \
#          --versioning-configuration Status=Enabled
#        aws dynamodb create-table \
#          --table-name sound-light-tf-locks \
#          --attribute-definitions AttributeName=LockID,AttributeType=S \
#          --key-schema AttributeName=LockID,KeyType=HASH \
#          --billing-mode PAY_PER_REQUEST \
#          --region us-east-1
#
#   2. Copy the block below into providers.tf (replacing the commented stub),
#      fill in your account id, then run:
#
#        terraform init -migrate-state
#
# NOTE: an S3 state bucket and a PAY_PER_REQUEST lock table are free-tier
# friendly (negligible storage + on-demand requests).

terraform {
  backend "s3" {
    bucket         = "sound-light-tfstate-<your-account-id>"
    key            = "sound-light/dev/terraform.tfstate"
    region         = "us-east-1"
    dynamodb_table = "sound-light-tf-locks"
    encrypt        = true
  }
}
