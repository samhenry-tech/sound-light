# ---------------------------------------------------------------------------
# sound-light environment configuration
# Copy to `.env.local` and fill in. All client-exposed vars MUST be VITE_*.
#
# Only per-deployment identity values live here. Fixed infrastructure values
# (AWS region, DynamoDB table names) and the OAuth redirect URIs (derived from
# the running browser's origin) are hardcoded in the app — see
# src/auth/awsConfig.ts and the *config.ts files.
# ---------------------------------------------------------------------------

# --- Google Sign-In ---
# Google OAuth 2.0 *Web application* client ID (Google Cloud Console →
# APIs & Services → Credentials). Register http://localhost:3000 as an
# authorised JavaScript origin and
# http://localhost:3000/auth/google/callback as an authorised redirect URI.
VITE_GOOGLE_CLIENT_ID=

# --- Cognito Identity Pool (from `terraform output`) ---
# terraform output cognito_identity_pool_id
VITE_COGNITO_IDENTITY_POOL_ID=

# --- Spotify (app: "sound-light") ---
VITE_SPOTIFY_CLIENT_ID=a35ad70cf30442f0a53ba22a95e85c8e
# When "true", the Library search + playback use the bundled mock catalog instead
# of the real Spotify Web API / Web Playback SDK (no Premium account required).
VITE_SPOTIFY_MOCK=true

# --- Music provider selection ---
# Which backend implements the swappable MusicProvider interface. Default "spotify".
VITE_MUSIC_PROVIDER=spotify
