# ---------------------------------------------------------------------------
# atmos environment configuration
# Copy to `.env.local` and fill in. All client-exposed vars MUST be VITE_*.
# The app runs fully offline (localStorage data + mock Spotify) when the
# AWS / Spotify values below are left blank — handy for local development.
# ---------------------------------------------------------------------------

# --- AWS data API (API Gateway HTTP API base URL, from `terraform output`) ---
# Leave blank to use the in-browser localStorage adapter instead.
VITE_API_BASE_URL=

# --- Cognito (OIDC) — from `terraform output` ---
# Leave VITE_COGNITO_AUTHORITY blank to bypass auth in local dev.
VITE_COGNITO_AUTHORITY=
VITE_COGNITO_CLIENT_ID=
# Cognito Hosted UI domain, e.g. https://atmos-xxxx.auth.us-east-1.amazoncognito.com
VITE_COGNITO_HOSTED_UI=
# Where Cognito returns the user after login (must match an app-client callback URL)
VITE_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
VITE_COGNITO_LOGOUT_URI=http://localhost:3000

# --- Spotify (app: "atmos") ---
VITE_SPOTIFY_CLIENT_ID=a35ad70cf30442f0a53ba22a95e85c8e
# Must EXACTLY match a redirect URI registered on the Spotify app (trailing slash matters)
VITE_SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/
# When "true", the Library search + playback use the bundled mock catalog instead
# of the real Spotify Web API / Web Playback SDK (no Premium account required).
VITE_SPOTIFY_MOCK=true

# --- Music provider selection ---
# Which backend implements the swappable MusicProvider interface. Default "spotify".
VITE_MUSIC_PROVIDER=spotify
